{
  "name": "online-food-ordering-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run clean && concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "clean": "npx -y kill-port 5000 27017",
    "install:all": "npm --prefix client install && npm --prefix server install",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "start:server": "npm --prefix server start",
    "build": "npm --prefix client run build",
    "seed": "npm --prefix server run seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
